# Generate with: node -e "import('bcryptjs').then(b => console.log(b.hashSync('your-password', 12)))"
# IMPORTANT: Escape all $ signs with \$ in the hash value
HIKARI_ADMIN_PASSWORD_HASH=

# Your name (shown in the welcome message)
PUBLIC_OWNER_NAME=hikari

# Owner's timezone (IANA format) and display label
PUBLIC_OWNER_TIMEZONE=America/Toronto
PUBLIC_OWNER_TIMEZONE_LABEL=Toronto

# Spotify API credentials (optional — enables song attachment on journal entries)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Set to "true" for the original hikari.garden instance (shows GitHub link)
PUBLIC_ORIGINAL=false
